# Copy to .env and fill in. The VITE_* values are safe to expose (the anon key is
# a publishable key); the SERVICE ROLE key is secret and server-side only.

# Backend the frontend targets: "local" (default, Express+SQLite) or "supabase".
VITE_BACKEND=supabase

# Supabase project (Settings -> API).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-publishable-key

# Public origin used to build the check-in QR code. Defaults to the current
# origin if unset; set it to your deployed URL so the big screen's QR is correct.
VITE_PUBLIC_ORIGIN=https://your-site.pages.dev

# Server-side only — used by `npm run import:supabase`. NEVER prefix with VITE_
# (anything VITE_* is bundled into the browser). Keep this key secret.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
