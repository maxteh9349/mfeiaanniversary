{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:supabase",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/checkin", "destination": "/apps/checkin/index.html" },
    { "source": "/screen", "destination": "/apps/screen/index.html" },
    { "source": "/admin", "destination": "/apps/admin/index.html" },
    { "source": "/draw", "destination": "/apps/draw/index.html" },
    { "source": "/", "destination": "/apps/checkin/index.html" }
  ]
}
